# 이 파일은 "예시"입니다. 실제로 쓰려면 secrets.toml 이라는 이름으로 복사한 뒤
# GOOGLE_SHEET_API_URL 값을 본인의 Apps Script 웹앱 주소로 바꿔서 사용하세요.
#
# ⚠️ secrets.toml 파일은 절대로 GitHub에 올리면 안 됩니다 (.gitignore에 이미 포함되어 있음).
# Streamlit Cloud에 배포할 때는 이 파일 대신, 배포 사이트의 "Settings → Secrets" 메뉴에
# 아래 내용을 그대로 붙여넣으면 됩니다.

GOOGLE_SHEET_API_URL = "https://script.google.com/macros/s/여기에_본인_주소/exec"
